# ─── DATABASE ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@localhost:5432/xconnector?schema=public"

# ─── REDIS ───────────────────────────────────────────────────────────────────
# Redis connection URL (required for BullMQ queues)
REDIS_URL="redis://localhost:6379"

# ─── SECURITY ────────────────────────────────────────────────────────────────
# 32+ random bytes, used for HMAC-signed download URLs (never expose)
# Generate with: openssl rand -hex 32
CONNECTOR_SECRET="your-super-secret-256-bit-key-here"

# Shopify webhook secret (from Partners > App setup > Webhooks)
SHOPIFY_WEBHOOK_SECRET="your-shopify-webhook-secret"

# ─── SHOPIFY ─────────────────────────────────────────────────────────────────
# For single-shop mode (multi-shop stores these per-row in DB)
SHOPIFY_DOMAIN="your-store.myshopify.com"
SHOPIFY_ACCESS_TOKEN="shpat_..."

# ─── SMARTBILL ───────────────────────────────────────────────────────────────
SMARTBILL_EMAIL="your@email.com"
SMARTBILL_TOKEN="your-smartbill-api-token"
SMARTBILL_CIF="RO12345678"
SMARTBILL_SERIES="SERIE"           # invoice series, e.g. "GLA"
SMARTBILL_PAYMENT_SERIES=""        # receipt series (optional), e.g. "FSZ"
SMARTBILL_TAX_PERCENTAGE="19"      # 19 or 9 or 5
SMARTBILL_USE_STOCK="false"        # set true to decrement stock
SMARTBILL_WAREHOUSE=""             # warehouse name if useStock=true

# ─── GLS ─────────────────────────────────────────────────────────────────────
GLS_USERNAME="your-mygls-username"
GLS_PASSWORD="your-mygls-password"
GLS_CLIENT_NUMBER="553003585"
GLS_PICKUP_NAME="Firma SRL"
GLS_PICKUP_STREET="Str. Exemplu nr. 10"
GLS_PICKUP_CITY="Bucuresti"
GLS_PICKUP_ZIP="010101"
GLS_PICKUP_COUNTY="Ilfov"
GLS_PICKUP_PHONE="0712345678"

# ─── SAMEDAY ─────────────────────────────────────────────────────────────────
SAMEDAY_USERNAME="your-sameday-username"
SAMEDAY_PASSWORD="your-sameday-password"
SAMEDAY_PICKUP_POINT_ID=""         # auto-detected if empty
SAMEDAY_SERVICE_ID=""              # auto-detected if empty

# ─── S3 / OBJECT STORAGE ─────────────────────────────────────────────────────
# Leave empty to fall back to DB storage (base64 in Bytes column)
S3_BUCKET=""
S3_REGION="eu-central-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""                     # custom endpoint for Cloudflare R2, MinIO, etc.
S3_PUBLIC_URL=""                   # CDN prefix (optional, internal only)

# ─── QUEUE BEHAVIOUR ─────────────────────────────────────────────────────────
# Set to "true" on serverless (Vercel) to process webhooks synchronously
# Set to "false" (default) for self-hosted / Docker with separate worker process
PROCESS_INLINE="false"

# Default courier for new orders: "gls" or "sameday"
DEFAULT_COURIER="gls"

# Token expiry for signed PDF download URLs (seconds, default 7 days)
SIGNED_URL_TTL="604800"

# ─── GEOAPIFY (optional address validation) ──────────────────────────────────
GEOAPIFY_KEY=""

# ─── NEXT.JS PUBLIC URL ──────────────────────────────────────────────────────
# Used to build absolute URLs for tracking links, PDF endpoints
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
