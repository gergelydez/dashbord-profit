import { NextResponse } from 'next/server';

// ── Credențiale din Vercel Environment Variables ──────────────────────────
// GLS_USERNAME, GLS_PASSWORD, GLS_CLIENT_NUMBER — setate în Vercel Dashboard
const ENV_GLS_USER   = process.env.GLS_USERNAME    || '';
const ENV_GLS_PASS   = process.env.GLS_PASSWORD    || '';
const ENV_GLS_CLIENT = process.env.GLS_CLIENT_NUMBER || '553003585';

const GLS_WSDL = 'https://online.gls-romania.ro/webservices/soap_server.php?wsdl&ver=18.09.12.01';

export const GLS_SERVICES = {
  SM1:{ code:'SM1',label:'📱 SMS la livrare',      desc:'SMS trimis destinatarului la livrare',               param:'phone',  group:'Notificări' },
  SM2:{ code:'SM2',label:'📧 SMS + Email livrare', desc:'SMS și email notificare la livrare',                 param:'email',  group:'Notificări' },
  FDS:{ code:'FDS',label:'🕐 FlexDelivery Email',  desc:'Destinatarul alege ora/locul via email',             param:'email',  group:'Flex' },
  FSS:{ code:'FSS',label:'💬 FlexDelivery SMS',    desc:'Destinatarul alege ora/locul via SMS',               param:'phone',  group:'Flex' },
  SAT:{ code:'SAT',label:'📅 Livrare Sâmbătă',     desc:'Garantat livrat sâmbătă',                           param:null,     group:'Livrare' },
  T12:{ code:'T12',label:'⏰ Livrare până 12:00',  desc:'Garantat înainte de prânz',                         param:null,     group:'Livrare' },
  SBS:{ code:'SBS',label:'🏪 Shop/ParcelLocker',   desc:'Livrare la shop GLS sau parcel locker',             param:'shopId', group:'Livrare' },
  AOS:{ code:'AOS',label:'✍️ Semnătură',           desc:'Confirmare prin semnătură la livrare',              param:null,     group:'Livrare' },
  DPV:{ code:'DPV',label:'🏠 Numai adresă privată',desc:'Nu se lasă la vecin/recepție',                      param:null,     group:'Livrare' },
  INS:{ code:'INS',label:'🛡️ Asigurare',           desc:'Asigurare pentru valoarea declarată a coletului',   param:'value',  group:'Extra' },
  SDS:{ code:'SDS',label:'↩️ Shop Return',         desc:'Return facilitat prin shop GLS',                    param:null,     group:'Extra' },
  EXW:{ code:'EXW',label:'🚛 Ex Works',            desc:'Ridicare de la adresa expeditorului',               param:null,     group:'Extra' },
};

function cors() {
  return { 'Access-Control-Allow-Origin':'*','Access-Control-Allow-Methods':'GET,POST,OPTIONS','Access-Control-Allow-Headers':'*' };
}
export async function OPTIONS() {
  return new NextResponse(null, { status:200, headers:cors() });
}

function validateAddress(a) {
  const issues = [];
  if (!a.name||a.name.trim().length<3) issues.push('Nume destinatar lipsă sau prea scurt');
  if (!a.address||a.address.trim().length<5) issues.push('Adresa stradală incompletă');
  if (a.address && !/\d/.test(a.address)) issues.push('Adresa nu conține număr stradal');
  if (!a.city||a.city.trim().length<2) issues.push('Orașul lipsește');
  if (!a.phone||a.phone.replace(/\D/g,'').length<10) issues.push('Telefon invalid (minim 10 cifre)');
  if (a.zip && !/^\d{6}$/.test(a.zip.replace(/\s/g,''))) issues.push('Cod poștal invalid (6 cifre RO)');
  return issues;
}

function buildSOAP({ username, password, clientNumber, parcel, services }) {
  const now = new Date().toISOString();
  const pickupDate = new Date().toISOString().slice(0,10);
  let servicesXml = '';
  for (const [code, value] of Object.entries(services || {})) {
    if (value !== null && value !== false && value !== '') {
      servicesXml += `<Service Code="${code}" Params="${value === true ? '' : String(value).replace(/"/g,'')}" />`;
    }
  }
  return `<?xml version="1.0" encoding="UTF-8"?>
<DTU EmailAddress="${username}" Version="18.09.12.01" Created="${now}" RequestType="GlsApiRequest" MethodName="prepareLabels">
  <Auth><Username>${username}</Username><Password>${password}</Password></Auth>
  <Shipment SenderID="${clientNumber}" ExpSenderID="" PickupDate="${pickupDate}T00:00:00"
    ClientRef="${(parcel.clientRef||'').replace(/"/g,'')}"
    CODAmount="${parcel.codAmount||0}" CODCurr="${parcel.codCurr||'RON'}" CODRef="${(parcel.codRef||'').replace(/"/g,'')}"
    PCount="${parcel.pcount||1}" Info="${(parcel.info||'').slice(0,100).replace(/"/g,'')}" CustomsVal="" CustomsCurr="">
    <Address Name="${(parcel.consigName||'').replace(/"/g,'')}"
      Address="${(parcel.consigAddress||'').replace(/"/g,'')}"
      City="${(parcel.consigCity||'').replace(/"/g,'')}"
      ZipCode="${parcel.consigZip||''}"
      CountryCode="${parcel.consigCountry||'RO'}"
      Contact="${(parcel.consigContact||parcel.consigName||'').replace(/"/g,'')}"
      Phone="${(parcel.consigPhone||'').replace(/\D/g,'').slice(-10)}"
      Email="${parcel.consigEmail||''}" />
    <Services>${servicesXml}</Services>
  </Shipment>
</DTU>`;
}

function parseGLSResponse(xml) {
  const awb = (xml.match(/PclNum="([^"]+)"/i)||[])[1] || null;
  const pdf = (xml.match(/<[Pp]df[Dd]ata[^>]*>([A-Za-z0-9+/=\s]+)<\/[Pp]df[Dd]ata>/)||[])[1]?.replace(/\s/g,'') || null;
  const error = (xml.match(/ErrorDescription="([^"]+)"/i)||xml.match(/<Error[^>]*>([^<]+)<\/Error>/i)||[])[1] || null;
  const success = !!(awb || (!error && xml.includes('successfull="true"')));
  return { awb, pdf, error, success };
}

export async function POST(request) {
  try {
    const body = await request.json();

    // Returnează config din env (pentru frontend să știe dacă e configurat)
    if (body.action === 'get_config') {
      return NextResponse.json({
        ok: true,
        configured: !!(ENV_GLS_USER && ENV_GLS_PASS),
        clientNumber: ENV_GLS_CLIENT,
        services: GLS_SERVICES,
      }, { headers: cors() });
    }

    if (body.action === 'get_services') {
      return NextResponse.json({ ok:true, services:GLS_SERVICES }, { headers:cors() });
    }

    if (body.action === 'validate_address') {
      const issues = validateAddress(body.address||{});
      return NextResponse.json({ ok:true, valid:issues.length===0, issues }, { headers:cors() });
    }

    const {
      // Credențialele vin din env — fallback la cele trimise din frontend (dacă userul le-a introdus manual)
      username:    bodyUser,
      password:    bodyPass,
      clientNumber: bodyClient,
      recipientName, phone, email, address, city, zip, country,
      parcels, content, codAmount, codCurrency, orderName, orderId,
      selectedServices, manualAwb,
    } = body;

    if (manualAwb) return NextResponse.json({ ok:true, awb:manualAwb, mode:'manual' }, { headers:cors() });

    // Prioritate: env vars → fallback la ce trimite frontend-ul
    const username     = ENV_GLS_USER   || bodyUser   || '';
    const password     = ENV_GLS_PASS   || bodyPass   || '';
    const clientNumber = ENV_GLS_CLIENT || bodyClient || '';

    if (!username||!password||!clientNumber) {
      return NextResponse.json({
        error:'Credențiale GLS lipsă. Adaugă GLS_USERNAME, GLS_PASSWORD, GLS_CLIENT_NUMBER în Vercel Environment Variables.',
        hint:'Mergi la Vercel Dashboard → Project → Settings → Environment Variables'
      }, { status:400, headers:cors() });
    }

    const addrIssues = validateAddress({ name:recipientName, address, city, zip, phone });
    if (addrIssues.length) {
      return NextResponse.json({ error:'Adresă invalidă: '+addrIssues.join('; '), addressIssues:addrIssues, requiresCorrection:true }, { status:422, headers:cors() });
    }

    const services = {};
    for (const [code, value] of Object.entries(selectedServices||{})) {
      if (value!==false && value!==null && value!=='') services[code] = value;
    }

    const soap = buildSOAP({ username, password, clientNumber, parcel: {
      consigName:recipientName, consigAddress:address, consigCity:city,
      consigZip:zip||'', consigCountry:country||'RO', consigContact:recipientName,
      consigPhone:(phone||''), consigEmail:email||'',
      codAmount:parseFloat(codAmount)||0, codCurr:codCurrency||'RON', codRef:orderName||'',
      pcount:parseInt(parcels)||1, clientRef:orderName||'', info:content||`Comanda ${orderName}`,
    }, services });

    const res = await fetch(GLS_WSDL, {
      method:'POST',
      headers:{ 'Content-Type':'text/xml; charset=UTF-8', 'SOAPAction':'prepareLabels' },
      body:soap, cache:'no-store',
    });
    const xml = await res.text();
    const parsed = parseGLSResponse(xml);
    if (!parsed.success||!parsed.awb) {
      return NextResponse.json({ error:parsed.error||'GLS SOAP: răspuns fără AWB', _raw:xml.slice(0,500) }, { status:500, headers:cors() });
    }
    return NextResponse.json({ ok:true, awb:parsed.awb, pdf:parsed.pdf, orderId, orderName, servicesApplied:Object.keys(services) }, { headers:cors() });

  } catch(e) {
    return NextResponse.json({ error:e.message }, { status:500, headers:cors() });
  }
}

export async function GET(request) {
  const { searchParams } = new URL(request.url);
  if (searchParams.get('action')==='services') {
    return NextResponse.json({ ok:true, services:GLS_SERVICES }, { headers:cors() });
  }
  // Test conexiune folosind env vars
  return NextResponse.json({
    ok: !!(ENV_GLS_USER && ENV_GLS_PASS),
    configured: !!(ENV_GLS_USER && ENV_GLS_PASS),
    clientNumber: ENV_GLS_CLIENT,
    message: ENV_GLS_USER ? 'GLS configurat din Vercel env vars.' : 'GLS_USERNAME lipsă din Vercel env vars.',
    services: GLS_SERVICES,
  }, { headers:cors() });
}
