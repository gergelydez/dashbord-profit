import { NextResponse } from 'next/server';

const ENV_GLS_USER   = process.env.GLS_USERNAME   || process.env.GLS_APP_ID      || '';
const ENV_GLS_PASS   = process.env.GLS_PASSWORD   || process.env.GLS_API_SECRET  || process.env.GLS_API_KEY || '';
const ENV_GLS_CLIENT = process.env.GLS_CLIENT_NUMBER || '553003585';

// GLS Romania MyGLS API endpoint
const GLS_API_BASE = 'https://api.mygls.ro';
// Fallback SOAP
const GLS_SOAP = 'https://online.gls-romania.ro/webservices/soap_server.php?wsdl&ver=18.09.12.01';

export const GLS_SERVICES = {
  SM1:{code:'SM1',label:'📱 SMS la livrare',group:'Notificări'},
  SM2:{code:'SM2',label:'📧 SMS + Email',group:'Notificări'},
  FDS:{code:'FDS',label:'🕐 FlexDelivery Email',group:'Flex'},
  FSS:{code:'FSS',label:'💬 FlexDelivery SMS',group:'Flex'},
  SAT:{code:'SAT',label:'📅 Livrare Sâmbătă',group:'Livrare'},
  T12:{code:'T12',label:'⏰ Până la 12:00',group:'Livrare'},
  SBS:{code:'SBS',label:'🏪 Shop/ParcelLocker',group:'Livrare'},
  AOS:{code:'AOS',label:'✍️ Semnătură',group:'Livrare'},
  DPV:{code:'DPV',label:'🏠 Numai adresă privată',group:'Livrare'},
  INS:{code:'INS',label:'🛡️ Asigurare',group:'Extra'},
  SDS:{code:'SDS',label:'↩️ Shop Return',group:'Extra'},
};

function cors() {
  return {
    'Access-Control-Allow-Origin':'*',
    'Access-Control-Allow-Methods':'GET,POST,OPTIONS',
    'Access-Control-Allow-Headers':'*'
  };
}
export async function OPTIONS() {
  return new NextResponse(null,{status:200,headers:cors()});
}

// Test autentificare MyGLS REST API
async function testMyGLSAuth(username, password, clientNumber) {
  const res = await fetch(`${GLS_API_BASE}/api/v1/token/generate`, {
    method:'POST',
    headers:{'Content-Type':'application/json','Accept':'application/json'},
    body: JSON.stringify({ username, password, clientNumber: parseInt(clientNumber)||0 }),
    cache:'no-store',
  });
  const text = await res.text();
  let data;
  try { data = JSON.parse(text); } catch { data = { error: text.slice(0,200) }; }
  if (!res.ok) throw new Error(data?.error || data?.message || `MyGLS Auth ${res.status}: ${text.slice(0,150)}`);
  return data.access_token || data.token || data.Token || null;
}

// Generare AWB prin SOAP (metoda clasică)
function buildSOAP({username,password,clientNumber,parcel,services}) {
  const pickupDate = new Date().toISOString().slice(0,10);
  let svcXml = '';
  for(const [code,val] of Object.entries(services||{})) {
    if(val!==false&&val!==null&&val!=='') svcXml+=`<Service Code="${code}" Params="${val===true?'':String(val)}"/>`;
  }
  return `<?xml version="1.0" encoding="UTF-8"?>
<DTU EmailAddress="${username}" Version="18.09.12.01" RequestType="GlsApiRequest" MethodName="prepareLabels">
  <Auth><Username>${username}</Username><Password>${password}</Password></Auth>
  <Shipment SenderID="${clientNumber}" PickupDate="${pickupDate}T00:00:00"
    ClientRef="${(parcel.clientRef||'').replace(/"/g,'')}"
    CODAmount="${parcel.codAmount||0}" CODCurr="${parcel.codCurr||'RON'}" CODRef="${(parcel.codRef||'').replace(/"/g,'')}"
    PCount="${parcel.pcount||1}" Info="${(parcel.info||'').slice(0,100).replace(/"/g,'')}">
    <Address Name="${(parcel.consigName||'').replace(/"/g,'')}"
      Address="${(parcel.consigAddress||'').replace(/"/g,'')}"
      City="${(parcel.consigCity||'').replace(/"/g,'')}"
      ZipCode="${parcel.consigZip||''}"
      CountryCode="RO"
      Phone="${(parcel.consigPhone||'').replace(/\D/g,'').slice(-10)}"
      Email="${parcel.consigEmail||''}"/>
    <Services>${svcXml}</Services>
  </Shipment>
</DTU>`;
}

export async function GET() {
  return NextResponse.json({
    ok: !!(ENV_GLS_USER && ENV_GLS_PASS),
    configured: !!(ENV_GLS_USER && ENV_GLS_PASS),
    clientNumber: ENV_GLS_CLIENT,
    message: ENV_GLS_USER
      ? `GLS configurat (${ENV_GLS_USER}). Apasă Test pentru verificare.`
      : 'GLS_USERNAME lipsește din Vercel env vars.',
    services: GLS_SERVICES,
  }, {headers:cors()});
}

export async function POST(request) {
  try {
    const body = await request.json();

    if(body.action==='get_services') {
      return NextResponse.json({ok:true,services:GLS_SERVICES},{headers:cors()});
    }

    // ── TEST CONEXIUNE ─────────────────────────────────────────────────
    if(body.action==='get_config'||body.action==='test_connection') {
      const user   = body.username     || ENV_GLS_USER   || '';
      const pass   = body.password     || ENV_GLS_PASS   || '';
      const client = body.clientNumber || ENV_GLS_CLIENT || '553003585';

      if(!user||!pass) {
        return NextResponse.json({ok:false,configured:false,
          error:'Completează username și parola GLS.'},{headers:cors()});
      }

      // Încearcă MyGLS REST API mai întâi (mai nou, mai rapid)
      try {
        const token = await testMyGLSAuth(user, pass, client);
        if(token) {
          return NextResponse.json({ok:true,configured:true,clientNumber:client,
            message:`GLS conectat via MyGLS API! Client: ${client}`},{headers:cors()});
        }
      } catch(restErr) {
        // REST a eșuat — încearcă SOAP clasic
        try {
          const soap = buildSOAP({username:user,password:pass,clientNumber:client,parcel:{
            consigName:'Test',consigAddress:'Str Test 1',consigCity:'Bucuresti',
            consigZip:'010101',consigPhone:'0700000000',consigEmail:'',
            codAmount:0,pcount:1,clientRef:'TEST',info:'Test',
          },services:{}});

          const res = await fetch(GLS_SOAP,{
            method:'POST',
            headers:{'Content-Type':'text/xml; charset=UTF-8','SOAPAction':'prepareLabels'},
            body:soap,cache:'no-store',
          });
          const xml = await res.text();
          const low = xml.toLowerCase();
          // Auth error explicit
          if(low.includes('invalid user')||low.includes('authentication failed')||
             low.includes('wrong password')||(low.includes('error')&&low.includes('user'))) {
            return NextResponse.json({ok:false,configured:false,
              error:'Credențiale GLS invalide. Verifică username/parolă în MyGLS.'},{headers:cors()});
          }
          // Dacă a răspuns fără eroare de auth = credențiale corecte
          return NextResponse.json({ok:true,configured:true,clientNumber:client,
            message:`GLS conectat via SOAP! Client: ${client}`},{headers:cors()});
        } catch(soapErr) {
          return NextResponse.json({ok:false,configured:false,
            error:`REST: ${restErr.message} | SOAP: ${soapErr.message}`},{headers:cors()});
        }
      }
    }

    // ── GENERARE AWB ───────────────────────────────────────────────────
    const {
      username:bUser,password:bPass,clientNumber:bClient,
      recipientName,phone,email,address,city,zip,country,
      parcels,content,codAmount,codCurrency,orderName,orderId,
      selectedServices,manualAwb,
    } = body;

    if(manualAwb) return NextResponse.json({ok:true,awb:manualAwb,mode:'manual'},{headers:cors()});

    const username = ENV_GLS_USER||bUser||'';
    const password = ENV_GLS_PASS||bPass||'';
    const clientNumber = ENV_GLS_CLIENT||bClient||'';

    if(!username||!password||!clientNumber) {
      return NextResponse.json({error:'Credențiale GLS lipsă.'},{status:400,headers:cors()});
    }

    const services={};
    for(const [code,val] of Object.entries(selectedServices||{})) {
      if(val!==false&&val!==null&&val!=='') services[code]=val;
    }

    const soap = buildSOAP({username,password,clientNumber,parcel:{
      consigName:recipientName,consigAddress:address,consigCity:city,
      consigZip:zip||'',consigPhone:phone||'',consigEmail:email||'',
      codAmount:parseFloat(codAmount)||0,codCurr:codCurrency||'RON',codRef:orderName||'',
      pcount:parseInt(parcels)||1,clientRef:orderName||'',info:content||`Comanda ${orderName}`,
    },services});

    const res = await fetch(GLS_SOAP,{
      method:'POST',
      headers:{'Content-Type':'text/xml; charset=UTF-8','SOAPAction':'prepareLabels'},
      body:soap,cache:'no-store',
    });
    const xml = await res.text();
    const awb = (xml.match(/PclNum="([^"]+)"/i)||[])[1];
    const pdf = (xml.match(/<[Pp]df[Dd]ata[^>]*>([A-Za-z0-9+/=\s]+)<\/[Pp]df[Dd]ata>/)||[])[1]?.replace(/\s/g,'')||null;
    const err = (xml.match(/ErrorDescription="([^"]+)"/i)||[])[1];

    if(!awb) return NextResponse.json({error:err||'GLS: AWB negăsit în răspuns',_raw:xml.slice(0,400)},{status:500,headers:cors()});
    return NextResponse.json({ok:true,awb,pdf,orderId,orderName},{headers:cors()});

  } catch(e) {
    return NextResponse.json({error:e.message},{status:500,headers:cors()});
  }
}
