import { NextResponse } from 'next/server';

const CORS = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Methods': 'POST,OPTIONS',
  'Access-Control-Allow-Headers': '*',
};

export async function OPTIONS() {
  return new NextResponse(null, { status: 200, headers: CORS });
}

async function nominatim(query) {
  try {
    const url = `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&limit=3&countrycodes=ro&addressdetails=1`;
    const res = await fetch(url, {
      headers: { 'User-Agent': 'ShipBridge/1.0' },
      cache: 'no-store',
      signal: AbortSignal.timeout(5000),
    });
    if (!res.ok) return [];
    return await res.json();
  } catch { return []; }
}

export async function POST(request) {
  try {
    const { name, address, city, county, zip, phone, skipEmpty } = await request.json();
    const issues = [];
    const zipClean = (zip || '').replace(/\s/g, '');

    // Adresa — prioritate mare
    if (!address || address.trim().length < 3) {
      issues.push({ field: 'address', msg: 'Adresa stradala lipseste sau e prea scurta' });
    } else if (!/\d/.test(address)) {
      issues.push({ field: 'address', msg: 'Adresa nu contine numar stradal' });
    }

    // ZIP
    if (zipClean && !/^\d{6}$/.test(zipClean)) {
      issues.push({ field: 'zip', msg: 'Codul postal trebuie sa aiba 6 cifre' });
    } else if (!zipClean) {
      issues.push({ field: 'zip', msg: 'Cod postal lipsa' });
    }

    // Oras
    if (!city || city.trim().length < 2) {
      issues.push({ field: 'city', msg: 'Orasul lipseste' });
    }

    // Telefon
    if (!skipEmpty || phone) {
      const digits = (phone || '').replace(/\D/g, '');
      if (digits.length > 0 && digits.length < 9) {
        issues.push({ field: 'phone', msg: 'Telefon prea scurt (minim 9 cifre)' });
      }
    }

    // Nume
    if (!skipEmpty && (!name || name.trim().length < 3)) {
      issues.push({ field: 'name', msg: 'Numele destinatarului lipseste' });
    }

    // NOMINATIM — cauta ZIP corect
    let suggestion = null;

    if (city) {
      // Cauta cu adresa completa
      const q1 = [address, city, county, 'Romania'].filter(Boolean).join(', ');
      const r1 = await nominatim(q1);

      let found = r1[0];

      // Daca nu a gasit cu adresa, cauta doar orasul
      if (!found || !found.address?.postcode) {
        const q2 = [city, county, 'Romania'].filter(Boolean).join(', ');
        const r2 = await nominatim(q2);
        if (r2.length > 0 && r2[0].address?.postcode) {
          found = r2[0];
        }
      }

      if (found) {
        const a = found.address || {};
        const road    = a.road || a.pedestrian || a.path || '';
        const houseNo = a.house_number || '';
        const sCity   = a.city || a.town || a.village || a.municipality || city;
        const sCounty = a.county || a.state_district || county || '';
        const sZip    = a.postcode || '';

        if (sZip) {
          const zipMismatch = !!(zipClean && zipClean !== sZip);
          const zipMissing  = !zipClean;

          suggestion = {
            formattedAddress: road && houseNo
              ? `${road} nr. ${houseNo}`
              : road || address || '',
            road, houseNumber: houseNo,
            city: sCity, county: sCounty, postcode: sZip,
            lat: parseFloat(found.lat), lon: parseFloat(found.lon),
            zipMismatch, zipMissing,
            zipMessage: zipMismatch
              ? `Cod postal incorect — corect este ${sZip} (actual: ${zipClean})`
              : zipMissing
                ? `Cod postal gasit pentru aceasta adresa: ${sZip}`
                : `Adresa verificata · ZIP: ${sZip}`,
          };

          // Actualizeaza eroarea de ZIP
          if (zipMismatch || zipMissing) {
            const idx = issues.findIndex(i => i.field === 'zip');
            const msg = {
              field: 'zip',
              msg: zipMismatch
                ? `Cod postal incorect — corect: ${sZip}`
                : `Cod postal lipsa — gasit: ${sZip}`,
            };
            if (idx >= 0) issues[idx] = msg;
            else issues.push(msg);
          }
        }
      }
    }

    return NextResponse.json({
      ok: true,
      valid: issues.filter(i => ['address', 'zip'].includes(i.field)).length === 0,
      issues,
      suggestion,
    }, { headers: CORS });

  } catch (e) {
    return NextResponse.json({ error: e.message }, { status: 500, headers: CORS });
  }
}
